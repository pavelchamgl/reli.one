description: React frontend rules
globs:
  - "Frontend/**/*.js"
  - "Frontend/**/*.jsx"
  - "Frontend/**/*.ts"
  - "Frontend/**/*.tsx"
  - "Frontend/**/*.css"
alwaysApply: false
