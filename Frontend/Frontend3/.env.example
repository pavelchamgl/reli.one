# Reli.one Frontend — environment variables
# Copy to .env.local for local development:
#   cp .env.example .env.local

# API base URL (без trailing slash)
# Production: https://reli.one/api
# Local:      http://localhost:8000/api
VITE_API_URL=https://reli.one/api

# Google OAuth Client ID
# Получить в Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# Sentry DSN (опционально, для мониторинга ошибок)
VITE_SENTRY_DSN=
