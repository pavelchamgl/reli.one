SECRET_KEY=CHANGE_ME_generate_with_django_get_random_secret_key
DEBUG=False

# --- Cookies / HTTPS (рекомендации для production за TLS-терминацией на Nginx) ---
# Локально и для HTTP e2e оставить False и SECURE_HSTS_SECONDS=0.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
# SECURE_SSL_REDIRECT: часто False за Nginx, если HTTP→HTTPS делает только edge (меньше риск циклов);
# True — только если Django должен сам редиректить небезопасные запросы (см. docs/07-deployment.md).
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_API_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...
PAYPAL_MODE=sandbox

CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

PACKETA_API_KEY=...
MYGLS_USERNAME=...
MYGLS_PASSWORD=...
DPD_TOKEN=...

clientSecret=
clientID=

# Google OAuth (allauth social login)
# Получить в Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry — мониторинг ошибок (опционально)
# Получить в Sentry → Project → Settings → Client Keys (DSN)
# Если не задан — Sentry не активируется. Активируется только при DEBUG=False.
SENTRY_DSN=
