# Копия: envs/database.test.env (файл с секретами не коммитить).
# DB_HOST = имя сервиса из docker-compose.test.yml (сеть Compose).

DB_HOST=postgres_test
DB_NAME=reli_test
DB_USER=reli_test
DB_PASS=change_me_test_only
DB_PORT=5432
DB_DRIVER=postgresql

# Образ postgres: официальные переменные — задавайте явно (подстановка ${DB_NAME} в env_file не работает).
POSTGRES_DB=reli_test
POSTGRES_USER=reli_test
POSTGRES_PASSWORD=change_me_test_only
