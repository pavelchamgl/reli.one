# Копия: envs/backend.test.env (файл с секретами не коммитить).
# Переменные из этого файла попадают в окружение контейнера первыми;
# load_dotenv в settings не перезаписывает уже заданные переменные.

SECRET_KEY=django-insecure-test-only-change-in-local-env-file
DEBUG=True

# Платёжные и внешние ключи — для интеграционных тестов с моками достаточно заглушек.
STRIPE_API_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_API_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_ENDPOINT_SECRET=whsec_test_placeholder

PAYPAL_CLIENT_ID=test_paypal_client_id
PAYPAL_CLIENT_SECRET=test_paypal_client_secret
PAYPAL_WEBHOOK_ID=test_paypal_webhook_id
PAYPAL_MODE=sandbox

# Cloudinary (опционально; пустой URL отключает типичные обращения к API, если код это допускает)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Доставка и прочие провайдеры — заглушки
PACKETA_API_KEY=
PACKETA_API_PASSWORD=
PACKETA_ESHOP_CODE=
MYGLS_USERNAME=
MYGLS_PASSWORD_SHA512=
DPD_TOKEN=

# ARES CZ company lookup (tests mock HTTP; no live ARES calls)
ARES_API_BASE=https://ares.gov.cz/ekonomicke-subjekty-v-be/rest
ARES_HTTP_TIMEOUT_CONNECT=5
ARES_HTTP_TIMEOUT_READ=10
ARES_HTTP_RETRIES=2
ARES_CACHE_SECONDS=86400

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Почта в тестах — in-memory
EMAIL_BACKEND=django.core.mail.backends.locmem.EmailBackend

# Task 013 — stock reservation (automated smoke uses @override_settings; set True for manual manage.py smoke)
STOCK_RESERVATION_ENABLED=False
STOCK_RESERVATION_TTL_MINUTES=35
