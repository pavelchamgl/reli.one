SECRET_KEY='change-me'
DEBUG=False
# Разрешить /api/delivery/dev/* (MyGLS/DPD) при DEBUG=False — только для стенда; в prod = False
ENABLE_DELIVERY_DEV_ENDPOINTS=False
ALLOWED_HOSTS="*"

# --- Cookies / HTTPS (HTTP local e2e: runserver без TLS; Secure=False обязателен) ---
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# Static / media для docker-compose.e2e (в контейнере пути /app/...; совпадает с environment в compose).
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# test my
STRIPE_API_PUBLISHABLE_KEY=''
STRIPE_API_SECRET_KEY=''
STRIPE_WEBHOOK_ENDPOINT_SECRET=''

# test my
PAYPAL_CLIENT_ID=''
PAYPAL_CLIENT_SECRET=''
PAYPAL_WEBHOOK_ID=''
PAYPAL_MODE=

PACKETA_ESHOP_CODE=
PACKETA_API_KEY=
PACKETA_API_PASSWORD=
PACKETA_API_LOCALE=en_GB
PACKETA_INVOICE_LOCALE=cs_CZ

# SMTP Mailpit
EMAIL_BACKEND='django.core.mail.backends.smtp.EmailBackend'
EMAIL_HOST='mailpit'
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Reli.one <noreply@reli.one>
SERVER_EMAIL=Reli.one Errors <errors@reli.one>
PROJECT_MANAGERS_EMAILS='["manager1@example.com","manager2@example.com"]'
EMAIL_TIMEOUT=10

#google oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#google oauth Frontend

# возможно это тестовые ключи gls
# нужно перепроверить для прода (на проде лежат такие же)
# вероятнее всего нужно поменять только саму ссылку MYGLS_API_BASE на прод
MYGLS_API_BASE=https://api.mygls.cz/ParcelService.svc/json
MYGLS_USERNAME=
MYGLS_PASSWORD_SHA512=b64:oNQqk5gDq/vcluiaCta ... 9AAZBFRLw==
MYGLS_WEBSHOP_ENGINE=
MYGLS_CLIENT_NUMBER=
MYGLS_TYPE_OF_PRINTER=A4_2x2   # или Thermo / A4_2x2 / A4_4x1
MYGLS_HTTP_TIMEOUT=15
MYGLS_HTTP_RETRIES=3
# Прайс-параметры:
FUEL_DIESEL_AVG_CZ=38              # пример, для экспорта (процент паливной надбавки посчитаем)
SEASONAL_SURCHARGE_ENABLED=true


# ========= DPD API =========
DPD_ENABLED=true
DPD_API_BASE=https://shipping.dpdgroup.com/api/v1.1

# Авторизация (Bearer)
DPD_TOKEN=

# Идентификаторы
DPD_CUSTOMER_ID=
DPD_SENDER_ADDRESS_ID=
DPD_BU_CODE=015

# Безопасный режим для dev/QA
#DPD_SHIP_SAVE_MODE=draft
# когда нужно полноценно проверить печать — временно меняешь на:
 DPD_SHIP_SAVE_MODE=printed

# Печать ярлыков
DPD_PRINT_FORMAT=PDF               # PDF | ZPL
DPD_LABEL_SIZE=A6                  # A4 | A6
DPD_LABEL_DIR=dpd_labels           # подпапка в MEDIA_ROOT
DPD_LABEL_START_POSITION=1         # 1..4 (только для A4 пакетной печати; можно не использовать)

# Параметры сети / ретраи
DPD_TIMEOUT_CONNECT=10
DPD_TIMEOUT_READ=30
DPD_RETRIES=3

# Телефон по умолчанию (плюс-код страны, если не пришёл в заказе)
DPD_PHONE_DEFAULT_PREFIX=420       # CZ

# (опционально) для /pickup если нужен иной адрес, чем senderAddressId
DPD_INTERNAL_PICKUP_ADDRESS_ID=

# (опционально) COD
DPD_COD_CURRENCY=EUR

# Google Merchant Center feed
PUBLIC_DOMAIN=https://reli.one
FEED_CURRENCY=EUR
GMC_FEED_RELATIVE_PATH=feeds/google.xml
